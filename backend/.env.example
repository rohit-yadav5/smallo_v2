# backend/.env.example — TTS environment variable overrides
#
# Copy to backend/.env and uncomment lines you want to change.
# All values shown are the defaults — omitting a variable uses the default.

# ── Kokoro settings ───────────────────────────────────────────────────────────

# Path to the Kokoro ONNX model file.
# Default: kokoro-models/kokoro-v1.0.onnx relative to the project root.
# TTS_KOKORO_MODEL_PATH=kokoro-models/kokoro-v1.0.onnx

# Path to the Kokoro voices binary file.
# TTS_KOKORO_VOICES_PATH=kokoro-models/voices-v1.0.bin

# Voice name. Run `kokoro.get_voices()` to see all 28 English options.
# af_sarah (American female) chosen as default: RTF≈0.26, clear and natural.
# Other good options: bf_emma (British female, RTF≈0.26), af_heart (RTF≈0.52).
# TTS_KOKORO_VOICE=af_sarah

# Speech speed multiplier. 1.0 = natural pace. 1.1 = slightly faster (default).
# TTS_KOKORO_SPEED=1.1

# Native Kokoro output sample rate in Hz. Do not change unless using a different model.
# TTS_SAMPLE_RATE=24000

# Native sample rate of the local audio output device (Hz).
# Auto-detected from sounddevice at startup — override only if auto-detection
# picks the wrong device (e.g. HDMI output instead of built-in speakers).
# macOS built-in speakers are typically 44100 Hz. Linux often 48000 Hz.
# TTS_DEVICE_SAMPLE_RATE=44100

# ── Sentence splitting ────────────────────────────────────────────────────────

# Regex pattern used to split LLM output into sentences before synthesis.
# Default splits after .!? and also , ; : — to avoid holding long comma-heavy
# sentences in the buffer until the final period (prevents 2-3s audio gaps).
# TTS_SENTENCE_SPLIT=(?<=[.!?,;:\u2014])\s+

# Flush the buffer as a chunk when it exceeds this many characters with no split.
# Prevents run-on sentences from stalling audio indefinitely.
# TTS_MAX_BUFFER_CHARS=120

# Minimum number of words a chunk must have before it is synthesized alone.
# Chunks shorter than this are held and merged with the next chunk.
# Higher values reduce stutter from comma fragments at the cost of slightly
# longer latency to first audio on short comma-split responses.
# TTS_MIN_CHUNK_WORDS=6

# Minimum character length a non-sentence-final chunk must reach before
# synthesis. Sentence-final punctuation (.!?) always flushes immediately
# regardless of this value. Works together with TTS_MIN_CHUNK_WORDS — both
# guards must be satisfied before a mid-sentence chunk is synthesized.
# TTS_TARGET_CHUNK_CHARS=80

# Seconds to wait before retrying a failed synthesis call.
# TTS_SYNTHESIS_RETRY_DELAY=0.05

# ── LLM conversation history ─────────────────────────────────────────────────

# Number of user+assistant message pairs to keep in the LLM's rolling context.
# 6 = 3 user turns + 3 assistant turns sent with every request.
# Set to 0 to disable conversation history (each turn is stateless).
# LLM_CONTEXT_TURNS=6

# ── Timing / latency ─────────────────────────────────────────────────────────

# Seconds to wait for the first LLM token before declaring Ollama hung.
# LLM_TOKEN_TIMEOUT_S=60.0

# How often (seconds) the playback polling loop checks for a barge-in interrupt.
# Smaller = more responsive; larger = fewer CPU wakeups. Default: 0.02 (20ms).
# TTS_POLL_INTERVAL_S=0.02

# Timeout (seconds) on each queue.get() in the main consumer loop.
# TTS_CONSUMER_POLL_S=0.05

# Timeout (seconds) on each queue.put() retry in the LLM producer thread.
# TTS_PRODUCER_RETRY_S=0.1

# ── Queue sizing ──────────────────────────────────────────────────────────────

# Number of LLM tokens the producer thread can buffer ahead of TTS synthesis.
# TTS_TOKEN_QUEUE_SIZE=64

# Max retries to deliver the end-of-stream sentinel when the queue is full.
# Total max wait ≈ TTS_SENTINEL_RETRIES × TTS_PRODUCER_RETRY_S (default: 10s).
# TTS_SENTINEL_RETRIES=100

# ── Logging ───────────────────────────────────────────────────────────────────

# Seconds between "waiting for first token..." heartbeat log lines.
# TTS_HEARTBEAT_INTERVAL_S=5.0

# Max characters of a sentence shown in the "[tts] synth #N ..." log line.
# TTS_LOG_SENTENCE_CHARS=55

# ── Remote audio delivery (WebSocket streaming) ───────────────────────────────

# Set to "true" to stream synthesized audio over WebSocket to browser clients.
# When false (default) audio is played locally via sounddevice only.
# TTS_REMOTE_AUDIO=false

# Audio encoding format sent to WebSocket clients.
# "pcm16" = raw signed-16-bit PCM (always available, larger payload)
# "opus"  = compressed Opus frames (requires opuslib, falls back to pcm16)
# TTS_AUDIO_FORMAT=pcm16

# Duration of each audio chunk sent over WebSocket, in milliseconds.
# Smaller = lower playback latency; larger = fewer messages. Default: 20ms.
# TTS_AUDIO_CHUNK_MS=20

# Set to "true" to ALSO play audio locally via sounddevice when remote_audio
# is enabled. Useful for monitoring audio on the server while clients receive it.
# TTS_MONITOR_LOCALLY=false
